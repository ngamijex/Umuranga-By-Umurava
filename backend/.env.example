# ─── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/umuranga?retryWrites=true&w=majority

# ─── JWT Auth ────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── OpenAI (screening + CV parsing) ─────────────────────
OPENAI_API_KEY=sk-your-key-here
# e.g. gpt-4o-mini (cheap), gpt-4o, gpt-4.1-mini — see https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-4o-mini

# Optional: delay between bulk/pipeline screenings (ms) to avoid 429s.
# LLM_MS_BETWEEN_CANDIDATES=2000
# (legacy) GEMINI_MS_BETWEEN_CANDIDATES=2000

# ─── File Uploads ────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ─── Cloudinary (production file storage) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Frontend URL (CORS) ─────────────────────────────────
# One origin, or comma-separated: https://app.vercel.app,https://preview-xxx.vercel.app
# Trailing slashes are ignored. For any Vercel preview hostname, set CORS_ALLOW_VERCEL_APP=1
FRONTEND_URL=http://localhost:3000
# CORS_ALLOW_VERCEL_APP=1

# ─── Email (applicant notifications — optional in dev) ───
# If SMTP_HOST is unset, “send” is simulated (logged to server console).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="Umuranga Hiring <hiring@yourcompany.com>"
