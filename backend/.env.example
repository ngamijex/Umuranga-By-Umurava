# ─── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/umuranga?retryWrites=true&w=majority

# ─── JWT Auth ────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── Gemini (screening + CV parsing) ─────────────────────
# Get a key from Google AI Studio. Set it on Render, do not commit real keys.
GEMINI_API_KEY=your_key_here
# e.g. gemini-2.5-flash (fast/cheap) or gemini-2.5-pro (higher quality)
GEMINI_MODEL=gemini-2.5-flash

# Optional: delay between bulk/pipeline screenings (ms) to avoid 429s.
# LLM_MS_BETWEEN_CANDIDATES=2000
# (legacy) GEMINI_MS_BETWEEN_CANDIDATES=2000

# ─── File Uploads ────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ─── Cloudinary (production file storage) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Frontend URL (CORS) ─────────────────────────────────
# Comma-separated origins. Production + preview, e.g.:
# FRONTEND_URL=https://myapp.vercel.app,https://myapp-git-main-user.vercel.app
FRONTEND_URL=http://localhost:3000
# Set to true on Render if preview URLs change often (allows any *.vercel.app origin).
# CORS_ALLOW_VERCEL_APP=true

# ─── Email (applicant notifications — optional in dev) ───
# If SMTP_HOST is unset, “send” is simulated (logged to server console).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="Umuranga Hiring <hiring@yourcompany.com>"
